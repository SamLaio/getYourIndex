{
  "manifest_version": 3,
  "name": "getYourIndex",
  "short_name": "getYourIndex",
  "version": "0.3",
  "author": "SamLiao",
  "description": "Configure what happens when a new tab is opened.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage", "tabs", "browserSettings"],
  "browser_specific_settings": {
    "gecko": {
      "id": "getyourindex@samliao",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["common.js", "background.js"]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "getYourIndex",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
